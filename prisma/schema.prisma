generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password         String
  role             String    @default("ADMIN")
  passwordChanged  Boolean   @default(false)
  resumeUrl        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  blogPosts        BlogPost[]
}

model Project {
  id            String    @id @default(cuid())
  slug          String    @unique
  githubUrl     String?
  liveUrl       String?
  featured      Boolean   @default(false)
  status        String    @default("DRAFT")
  order         Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  categories    Category[]
  tags          Tag[]
  translations  ProjectTranslation[]
  projectImages ProjectImage[]
}

model ProjectImage {
  id        String  @id @default(cuid())
  url       String
  order     Int     @default(0)
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectTranslation {
  id              String    @id @default(cuid())
  locale          String
  title           String
  description     String
  content         String?
  metaDescription String?
  projectId       String
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, locale])
}

model BlogPost {
  id            String    @id @default(cuid())
  slug          String    @unique
  coverImage    String?
  readingTime   Int       @default(5)
  featured      Boolean   @default(false)
  status        String    @default("DRAFT")
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  authorId      String?
  author        User?     @relation(fields: [authorId], references: [id])
  categories    Category[]
  tags          Tag[]
  translations  BlogPostTranslation[]
}

model BlogPostTranslation {
  id              String    @id @default(cuid())
  locale          String
  title           String
  excerpt         String
  content         String
  metaDescription String?
  blogPostId      String
  blogPost        BlogPost  @relation(fields: [blogPostId], references: [id], onDelete: Cascade)

  @@unique([blogPostId, locale])
}

model Category {
  id            String    @id @default(cuid())
  slug          String    @unique
  name          String

  projects      Project[]
  blogPosts     BlogPost[]
}

model Tag {
  id            String    @id @default(cuid())
  slug          String    @unique
  name          String

  projects      Project[]
  blogPosts     BlogPost[]
}

model ContactMessage {
  id            String    @id @default(cuid())
  name          String
  email         String
  subject       String?
  message       String
  read          Boolean   @default(false)
  createdAt     DateTime  @default(now())
}

model Service {
  id            String    @id @default(cuid())
  slug          String    @unique
  icon          String?
  featured      Boolean   @default(false)
  status        String    @default("DRAFT")
  order         Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  translations  ServiceTranslation[]
}

model ServiceTranslation {
  id            String    @id @default(cuid())
  locale        String
  title         String
  shortDesc     String
  description   String
  features      String?
  serviceId     String
  service       Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, locale])
}

model Media {
  id          String        @id @default(cuid())
  filename    String
  url         String        @unique
  mimeType    String
  size        Int
  alt         String?
  folderId    String?
  folder      MediaFolder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  createdAt   DateTime      @default(now())
}

model MediaFolder {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  media     Media[]
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  userAgent String?
  country   String?
  sessionId String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([path])
  @@index([createdAt])
  @@index([sessionId])
}

model AiProfile {
  id        String      @id @default(cuid())
  name      String
  provider  String      @default("ollama")
  apiKey    String?
  baseUrl   String?
  model     String      @default("llama3")
  isDefault Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  activeIn  AiSettings?
}

model AiSettings {
  id              String    @id @default("default")
  tavilyApiKey    String?
  activeProfileId String?   @unique
  activeProfile   AiProfile? @relation(fields: [activeProfileId], references: [id], onDelete: SetNull)
  updatedAt       DateTime  @updatedAt
}

model SocialAccount {
  id                String        @id @default(cuid())
  provider          String        // "telegram"
  providerAccountId String        // Telegram chat_id
  name              String        // Display name (e.g. "Telegram Bot")
  accessToken       String        // AES-256-GCM encrypted bot token
  refreshToken      String?       // Unused (kept for schema compatibility)
  tokenExpiry       DateTime?     // Unused (kept for schema compatibility)
  isActive          Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  posts             SocialPost[]
}

model SocialPost {
  id             String        @id @default(cuid())
  content        String        // The post text
  platform       String        // "linkedin" | "facebook"
  tone           String?       // "professional" | "viral" | "mix"
  status         String        @default("DRAFT") // DRAFT | SENT | FAILED
  platformPostId String?       // Telegram message_id
  errorMessage   String?       // Error details if failed
  publishedAt    DateTime?
  createdAt      DateTime      @default(now())
  accountId      String
  account        SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}


